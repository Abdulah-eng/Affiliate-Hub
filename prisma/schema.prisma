generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User role definition
enum Role {
  AGENT
  CSR
  ADMIN
}

enum Currency {
  PTS
  GCASH
}

// Application status definition
enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  REQUEST_REUPLOAD
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(AGENT)

  // Agent Specific
  username String? @unique
  password String?

  // Profile Details
  firstName         String?
  lastName          String?
  fbProfileName     String?
  mobileNumber      String?
  address           String?
  city              String?
  affiliateUsername String?
  location          String?
  referralSource    String?

  // KYC Info
  kycStatus      KycStatus @default(PENDING)
  kycSubmittedAt DateTime?
  kycReviewedAt  DateTime?
  kycNotes       String?

  // Primary ID
  kycIdType   String?
  kycIdNumber String?
  idPhotoUrl  String? // Serving as Front URL for backwards compatibility
  idBackUrl   String?

  // Secondary ID 1
  kycSecondaryId1Type     String?
  kycSecondaryId1Number   String?
  kycSecondaryId1FrontUrl String?
  kycSecondaryId1BackUrl  String?

  // Secondary ID 2
  kycSecondaryId2Type     String?
  kycSecondaryId2Number   String?
  kycSecondaryId2FrontUrl String?
  kycSecondaryId2BackUrl  String?

  // Selfie
  selfieUrl     String? // Selfie with ID
  agreedToTerms Boolean @default(false)

  referralCode String? @unique
  referrerId   String?

  // Relations
  referrer  User?  @relation("Referrals", fields: [referrerId], references: [id])
  referrals User[] @relation("Referrals")

  platforms     PlatformAccess[]
  transactions  PointTransaction[]
  chatMessages  ChatMessage[]
  notifications Notification[]
  withdrawals   Withdrawal[]
  taskProgress  UserTaskProgress[]
  promoSubmissions PromoSubmission[]
  dailyTasks    UserDailyTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Partner Brands
model Brand {
  id       String  @id @default(cuid())
  name     String  @unique
  logoUrl  String?
  loginUrl String?
  status   String  @default("ONLINE") // ONLINE, MAINTENANCE
  useIframe Boolean @default(false)
  description String?
  isActive  Boolean @default(true)

  accessItems PlatformAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// The credentials mapping for an agent to a specific partner brand
model PlatformAccess {
  id       String  @id @default(cuid())
  userId   String
  brandId  String
  username String?
  password String?
  status   String  @default("PENDING") // PENDING, APPROVED, REJECTED

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
}

// Gamification and Wallet
model PointTransaction {
  id          String  @id @default(cuid())
  userId      String
  amount      Int
  currency    Currency @default(PTS)
  type        String // REFERRAL, CHAT, LOGIN_STREAK, REDEMPTION
  description String?
  status      String  @default("COMPLETED") // COMPLETED, PENDING, FLAGGED

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Public Agent Chat
model ChatMessage {
  id      String @id @default(cuid())
  userId  String
  content String

  // Rewards linked to this message if any
  rewardPoints Int @default(0)

  reactions   Json?    @default("[]") // Store as array of {userId, type}
  isSpam      Boolean  @default(false)
  isHelpful   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Global configuration
model SystemSetting {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  description String?

  updatedAt DateTime @updatedAt
}

// System notifications for agents
model Notification {
  id      String  @id @default(cuid())
  userId  String
  title   String
  message String
  type    String  @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  isRead  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Agent withdrawal/payout requests
model Withdrawal {
  id             String   @id @default(cuid())
  userId         String
  amount         Int
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  paymentMethod  String // Bank Transfer
  paymentDetails String // Account number details
  notes          String?
  proofUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  points      Int
  type        String   @default("VIDEO") // VIDEO, SOCIAL, etc.
  videoUrl    String?
  isExternal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userProgress UserTaskProgress[]
}

model UserTaskProgress {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  status      String   @default("COMPLETED")
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
}

model Promo {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  imageUrl    String?
  active      Boolean  @default(true)
  
  requiresVerification Boolean @default(false)
  pointsAward          Int @default(0)
  currency             Currency @default(PTS)

  submissions PromoSubmission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromoSubmission {
  id           String   @id @default(cuid())
  promoId      String
  userId       String
  screenshotUrl String
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedAt   DateTime?
  
  promo        Promo    @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
}

model UserDailyTask {
  id          String   @id @default(cuid())
  userId      String
  taskKey     String   // e.g., "DAILY_LOGIN", "FIRST_CHAT", "CHAT_LIKES"
  count       Int      @default(0)
  lastResetAt DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskKey])
}

model WhitelistEntry {
  id        String   @id @default(cuid())
  value     String   @unique // IP or Username
  type      String   // IP, USERNAME
  reason    String?
  addedBy   String?
  createdAt DateTime @default(now())
}
